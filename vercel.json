{
  "crons": [
    { "path": "/api/mastodon-post?secret=${CRON_SECRET}", "schedule": "3 2 * * *" },
    { "path": "/api/mastodon-post?secret=${CRON_SECRET}", "schedule": "7 10 * * *" },
    { "path": "/api/mastodon-post?secret=${CRON_SECRET}", "schedule": "13 18 * * *" },
