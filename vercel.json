    { "source": "/", "has": [{ "type": "host", "value": "www.paintwise.xyz" }], "destination": "https://paintwise.xyz/", "permanent": true },
    { "source": "/:path*", "has": [{ "type": "host", "value": "www.paintwise.xyz" }], "destination": "https://paintwise.xyz/:path*", "permanent": true },
    { "source": "/", "has": [{ "type": "host", "value": "www.aitoolshelf.xyz" }], "destination": "https://aitoolshelf.xyz/", "permanent": true },
    { "source": "/:path*", "has": [{ "type": "host", "value": "www.aitoolshelf.xyz" }], "destination": "https://aitoolshelf.xyz/:path*", "permanent": true },
